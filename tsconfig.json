{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./js",
    

    "module": "ESNext",
    "target": "ES2020",

    "sourceMap": false,

    "declaration": false,
    "declarationMap": false,

    "strict": true,
    "esModuleInterop": true,

    "jsx": "react-jsx",

    "isolatedModules": false,
    "verbatimModuleSyntax": false,

    "skipLibCheck": true
  },

  "include": ["src/**/*"]
}